{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/dev/packages/vscode-tauri/src/lib/schema.json",
  "productName": "VanishTrans",
  "version": "0.1.0",
  "identifier": "com.vanish-trans.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",


        "width": 420,
        "height": 520,
        "minWidth": 320,
        "minHeight": 360,
        "resizable": true,
        "decorations": true,
        "center": true,


        "visible": false,


        "skipTaskbar": true,


        "alwaysOnTop": false,


        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:; img-src 'self' asset: data: https:; font-src 'self'"
    }
  },
  "plugins": {
    "global-shortcut": null,
    "clipboard-manager": null
  }
}
